# =========================
# Build output
# =========================
target/
build/
out/
bin/
dist/

# Keep source folders even if nested build-like names appear
!**/src/main/**/build/
!**/src/test/**/build/
!**/src/main/**/target/
!**/src/test/**/target/

# =========================
# Java / Maven
# =========================
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

.mvn/timing.properties
dependency-reduced-pom.xml
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
.flattened-pom.xml

# =========================
# Logs
# =========================
logs/
*.log
*.log.*
hs_err_pid*
replay_pid*

# =========================
# IDE - IntelliJ IDEA
# =========================
.idea/
*.iml
*.ipr
*.iws

# =========================
# IDE - Eclipse / STS
# =========================
.classpath
.project
.settings/
.springBeans
.sts4-cache
.factorypath
.apt_generated/

# =========================
# IDE - VS Code
# =========================
.vscode/

# =========================
# NetBeans
# =========================
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
Desktop.ini

# =========================
# Environment / secrets
# =========================
.env
.env.*
*.env
secrets/
*.pem
*.key
*.p12
*.jks

# Ignore local override configs, but keep template/example configs
application-local.yml
application-local.yaml
application-dev-local.yml
application-secrets.yml
application-secrets.yaml

# =========================
# Docker / containers
# =========================
*.pid
*.seed
*.pid.lock

# =========================
# Temporary files
# =========================
*.swp
*.swo
*~
*.tmp
*.temp

# =========================
# Test / coverage
# =========================
coverage/
.coverage
jacoco.exec

# =========================
# Generated docs / reports
# =========================
/site/
docs/.cache/

# =========================
# Database / local runtime files
# =========================
*.db
*.mv.db
*.trace.db
*.h2.db

